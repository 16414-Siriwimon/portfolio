างแดน","key":"","taxonomyId":"5ef97ee9282bfa775f3db230"}],"galleryId":"5f7ad19d3ce21e00ded38e61","contentTimestampedAt":"2020-10-05T04:30:00.000Z","createdAt":"2020-10-05T06:45:37.131Z","updatedAt":"2020-10-06T05:16:12.480Z","path":"/programs/activity/5f7ac1113ce21e719fd37307?type=episode","url":"https://altv.thaipbs.or.th/programs/activity/5f7ac1113ce21e719fd37307?type=episode","previewUrl":"https://console.altv.tv/api/content/v2/episodes/5f7ac1113ce21e719fd37307/preview"},"attachmentId":null,"attachment":null,"categoryId":"5ef97f10282bfa8eda3db231","media":{"videoType":"vod","type":"qoder","sourceKey":"SCbClaYwfm1k","sources":[{"type":"application/x-mpegURL","src":"https://vod.thaipbs.or.th/video-objects/SCbClaYwfm1k/playlist.m3u8"}],"embeddedUrl":"https://vod.thaipbs.or.th/videos/SCbClaYwfm1k/embedded","canonicalUrl":"https://vod.thaipbs.or.th/videos/SCbClaYwfm1k"},"category":{"id":"5ef97f10282bfa8eda3db231","name":"ชมย้อนหลัง","key":"episode","taxonomyId":"5ef97ea7282bfa818a3db22f"},"title":"หลงโตเกียว","tagline":"การปรับตัวในพื้นที่ต่างแดนเป็นเรื่องไม่ง่าย แต่ก็จำเป็นต้องทำเพื่อความอยู่รอดและเพื่อความฝันในอนาคตข้างหน้า","description":"\u003cp\u003eเพราะความหลงใหลในภาษาและวัฒนธรรมของประเทศญี่ปุ่น ทำให้ \"มะเดี่ยว\" ผู้สาวไทบ้านจากหนองคาย พยายามผลักดันตัวเองให้ได้มาทำงานที่นี่ และต้องยอมปรับตัวครั้งใหญ่ เพื่อที่จะใช้ชีวิตอยู่ให้ได้ภายใต้กฎระเบียบทางสังคมของประเทศนี้ เนื่องจากรูปแบบโครงสร้างวัฒนธรรมที่แข็งแรงของคนญี่ปุ่น ทำให้ \"มะเดี่ยว\" ต้องปกปิดเพศสภาพของตัวเองอย่างรัดกุม โชคดีที่เขาได้พบกับช่องทางการแสดงออกของกลุ่มคนที่มีความชอบแบบเดียวกัน จึงยังพอให้เขาสามารถมีพื้นที่ปลดปล่อยความรู้สึกลึก ๆ ออกมาได้\u003cstrong\u003e \u003c/strong\u003eการปรับตัวในพื้นที่ต่างแดนเป็นเรื่องไม่ง่าย แต่ก็จำเป็นต้องทำเพื่อความอยู่รอดและเพื่อความฝันในอนาคตข้างหน้า\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eติดตามเรื่องราวและความรู้สึกของคน ๆ หนึ่งที่ต้องดิ้นรนและเก็บงำความลับ ท่ามกลางบรรยากาศชวนอึดอัดใจ ในรายการ ก(ล)างเมือง ตอน หลงโตเกียว วันจันทร์ที่ 5 ต.ค. 63 เวลา 11.30 - 11.58
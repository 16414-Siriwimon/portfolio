type":"vod","key":"TXnZAtWAOqNF","episodeId":"63f4ba892a29b04a4c6fdbc7","attachmentId":null,"categoryId":"5ef97f10282bfa8eda3db231","media":{"videoType":"vod","type":"qoder","sourceKey":"TXnZAjtCXSiq","sources":[{"type":"application/x-mpegURL","src":"https://vod.thaipbs.or.th/video-objects/TXnZAjtCXSiq/playlist.m3u8"}],"embeddedUrl":"https://vod.thaipbs.or.th/videos/TXnZAjtCXSiq/embedded","canonicalUrl":"https://vod.thaipbs.or.th/videos/TXnZAjtCXSiq"},"title":"ดูแลข้างในบ้าน","tagline":"รายการขบวนการFunน้ำนม พาเด็ก ๆ ขึ้นขบวนแห่งความสุข ไปสนุกกับว่องไว แหลมคม นุ่มนิ่ม พี่เอม และ พี่มี้","description":"\u003cp\u003eรายการขบวนการFunน้ำนม พาเด็ก ๆ ขึ้นขบวนแห่งความสุข ไปสนุกกับว่องไว แหลมคม นุ่มนิ่ม พี่เอม และ พี่มี้ ที่จะพาเด็ก ๆ ไปพบกับหนังสือหรรษา วันนี้...เอ๊ะ นั่นใครกำลังแอบมองว่องไว แหลมคม นุ่มนิ่มอยู่ แล้วทั้งสามกำลังทำอะไรอยู่กันนะ? มาวาดรูปแปลงร่างกันต่อกับพี่เอม ที่จะชวนเด็ก ๆ มาแปลงร่าง บ.ใบไม้ ให้สนุกสนานตีลังกาหงายหลังกันไปเลย แล้วไปพบกับจอมเวทย์ฝึกหัดที่จะมาช่วยกันร่ายคาถาทำภารกิจ เพื่อปลดปล่อยสัตว์วิเศษที่ถูกขังอยู่ในขวดเป็นเวลาล้านล้านล้านปี มาช่วยลุ้นให้จอมเวทย์ฝึกหัดทั้งสองผ่านภารกิจต่าง ๆ อย่างปลอดภัย และชวนเด็ก ๆ มาปิดท้ายด้วยการปลุกร่างกายให้สดชื่นกับพี่เอม และ ยินดี ที่พาเด็ก ๆ ลงไปออกลวดลายการเป็นนักเต้นเท้าไฟใต้ท้องทะเล\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eติดตามชมรายการ ขบวนการ FUN น้ำนม วันเสาร์ที่ 4 มี.ค. 66 เวลา 06.35 – 06.55 น. ทาง ALTV ทีวีเรียนสนุก ช่องหมายเลข 4\u003c/strong\u003e\u003c/p\u003e","firstAiredAt":"2023-03-03T23:35:00.000Z","status":"published","startPublish":"2023-03-07T06:47:28.715Z","endPublish":null,"tagIds":["6164042007a12175cdda6750","63f4ba8a2a29b02af26fdbc8","63cfb31f168b541ad8102f9a","63be76ee6b10037f9fb7a0f7","63edd62171327a29c0365029","622049dc07a12164c5be6f16","5efe09b438ea519cb9d7a2b8"],"isUsingEpisodeMetadata":true,"contentCategoryId":"5ef97f7b282bfa98033db235","ageCategoryId":"6345421cf7d30d761e385adc","subjectCategoryId":"634541fdf7d30d7d8f385ad8","galleryId":"63f4ba5a020bddf87674c117","coverImage":{"typ
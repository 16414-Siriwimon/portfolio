่นผสมการทดลองวิทยาศาสตร์ เพื่อปลูกฝังการเรียนรู้อย่างสนุก สร้างสรรค์ ให้เด็กและเยาวชนได้ฝึกฝน ประสบการณ์ และพัฒนาทักษะสติปัญญา ใช้ความคิดอย่างเป็นเหตุเป็นผล รู้จักตั้งคำถาม และทำการทดลองด้วยตนเอง อีกทั้งรู้จักใช้จินตนาการ เพื่อเชื่อมโยงความรู้ไปสู่การคิดค้น ทดลอง และประดิษฐ์สิ่งใหม่ๆ ได้ในอนาคต\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eรายการบ้านนักวิทยาศาสตร์น้อย ออกอากาศทุกวันเสาร์ - อาทิตย์ เวลา 06.55 - 07.05 น. ทาง ALTV ทีวีเรียนสนุก ช่องหมายเลข 4\u003c/strong\u003e\u003c/p\u003e","schedule":"เสาร์-อาทิตย์ I 06:55-07:05","features":{"audioDesc":false,"restrictedLicense":false,"soundtrack":false,"closedCaptions":false,"signLanguage":false,"id":null},"broadcastingChannels":{"facebook":false,"tv":true,"twitter":false,"web":true,"youtube":false,"id":null},"createdAt":"2020-06-30T10:10:25.360Z","updatedAt":"2025-02-25T09:05:43.644Z","__v":3,"contentCategoryId":"5ef97f7b282bfa98033db235","endPublish":null,"startPublish":"2020-06-30T10:12:52.422Z","updatedById":"609225fff6234f2e4f684ae8","mail":"Witnoi@ALTV.tv","website":"www.ALTV.tv/Witnoi","programCategoryId":null,"coverImage":{"_id":"67bd87e7e40e7210c363f822","type":"thumbor","urls":{"cover1280w720h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover1280w720h/image.jpg","cover640w360h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover640w360h/image.jpg","cover640w480h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover640w480h/image.jpg","cover320w180h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover320w180h/image.jpg","cover160w90h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover160w90h/image.jpg","cover720w1280h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover720w1280h/image.jpg","cover360w640h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover360w640h/image.jpg","cover180w320h":"https://images.altv.tv/images/generalCoverImage/7Ye27zVIN.png/cover180w3